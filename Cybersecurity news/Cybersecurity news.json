    {
      "parameters": {
        "jsCode": "// Lấy dữ liệu từ item đầu tiên\nconst articles = $input.first().json.data;\n\n// Lấy ngày hiện tại\nconst now = new Date();\nconst dd = String(now.getDate()).padStart(2, '0');\nconst mm = String(now.getMonth() + 1).padStart(2, '0');\nconst yyyy = now.getFullYear();\n\n// Hàm lấy domain an toàn (không dùng URL object)\nfunction getDomain(link) {\n  try {\n    return link.replace(/^https?:\\/\\//, '').split('/')[0].replace('www.', '');\n  } catch (e) {\n    return 'nguồn không xác định';\n  }\n}\n\n// Tạo bản tin\nlet text = `📰 *Bản tin Cyber Security ngày ${dd}/${mm}/${yyyy}:*\\n\\n`;\n\narticles.forEach((a, i) => {\n  const domain = getDomain(a.link);\n  text += `${i + 1}. ${a.title} ( Nguồn: [${domain}](${a.link}) )\\n\\n`;\n});\n\nreturn [{\n  json: {\n    message: text.trim()\n  }\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
